
<% layout('layouts/boilerplate') %>

<div class="row justify-content-center mt-4">
  <div class="col-lg-8 col-md-10">
    <div class="card shadow-sm">
      <h3><%= listing.title %></h3>
      <img
        src="<%= listing.image.url %>"
        class="card-img-top show-img"
        alt="Listing Image"
      />

      <div class="card-body">
        <!-- <h4 class="card-title mb-2"><%= listing.title %></h4> -->

        <p class="card-text text-muted mb-3">Owned By: <i><%= listing.owner?.username || "Unknown" %></i></p>



        <p class="card-text text-muted mb-3"><%= listing.description %></p>

        <p class="card-text">
          <strong>Price:</strong>
          <!-- .toLocaleString("en-IN") use for Indian Rupee formatting & &#8377; use for indian rupess symbol  -->
          &#8377; <%= listing.price.toLocaleString("en-IN") %> / night
        </p>

        <p class="card-text">
          <strong>Location:</strong>
          <%= listing.location %>, <%= listing.country %>
        </p>
      </div>
    </div>

    <!-- action buttons -->
<% if(currentUser && listing.owner && currentUser._id.equals(listing.owner._id)) { %>
      <div class="d-flex gap-3 mt-3">
      <a href="/listings/<%= listing._id %>/edit" class="btn btn-outline-dark">
        Edit
      </a>

      <form action="/listings/<%= listing._id %>?_method=DELETE" method="POST">
        <button type="submit" class="btn btn-danger">Delete</button>
      </form>
    </div>
    <% } %>


    <!-- Reviews Section -->
<div class="mt-5 ">

  <!-- Header -->
   <% if(!currentUser) { %>
  <div class="d-flex justify-content-between align-items-center mb-4">
      <h4 class="fw-bold">Reviews</h4>
  </div>
  <% } else {%>
  
    <div class="d-flex justify-content-between align-items-center mb-4">
      <h4 class="fw-bold">Reviews</h4>

      <a
        href="/listings/<%= listing._id %>/reviews/new"
        class="btn btn-dark btn-sm rounded-pill"
      >
        Write a review
      </a>
    </div>
  <% } %>

  <% if (listing.reviews.length === 0) { %>
    <p class="text-muted">No reviews yet.</p>
  <% } else { %>

    <!-- Reviews Grid -->
    <div class="row row-cols-1 row-cols-md-2 g-4">

      <% listing.reviews.forEach((review) => { %>
        <div class="col shadow-sm p-3 rounded">

          <div class="d-flex gap-3 ">

            <!-- Avatar -->
            <div>
              <div
                class="rounded-circle bg-dark text-white d-flex align-items-center justify-content-center"
                style="width: 48px; height: 48px;"
              >
                <strong><%= review.owner.username.charAt(0).toUpperCase() %></strong>
              </div>
            </div>

            <!-- Review Content -->
            <div>
              <!-- Name -->
              <h6 class="mb-0 fw-semibold"><%= review.owner.username %></h6>
              <!-- Date -->
              <small class="text-muted">
                <%= review.createdAt.toLocaleString('default', { month: 'long', year: 'numeric' }) %>
              </small>

              <!-- Stars -->
              <div class="text-warning mt-1">
                <% for(let i = 0; i < review.rating; i++) { %>
                  ★
                <% } %>
                <% for(let i = review.rating; i < 5; i++) { %>
                  ☆
                <% } %>
              </div>

            <!-- for checking the rating from github -->
<!--           
          <p class="starability-result" data-rating="<%= review.rating %>">
            
          </p> -->

                         <!-- Comment -->
              <p class="mt-2 text-secondary">
                <%= review.comment.length > 160
                  ? review.comment.slice(0, 160) + "..."
                  : review.comment
                %>
              </p>

              <% if (review.comment.length > 160) { %>
                <a href="#" class="fw-semibold text-decoration-underline text-dark">
                  Show more
                </a>
              <% } %>
            </div>
          </div>
          
                      <div class="mt-3  gap-2 justify-content-end">
            <!-- Edit & Delete Buttons -->
             <% if(currentUser && currentUser._id.equals(review.owner._id)) { %>
          <div class="mt-3 d-flex gap-2 justify-content-end">
            <a
              href="/listings/<%= listing._id %>/reviews/<%= review._id %>/edit"
              class="btn btn-outline-dark btn-sm"
            >
              Edit
            </a>

            <form
              action="/listings/<%= listing._id %>/reviews/<%= review._id %>?_method=DELETE"
              method="POST"
            >
              <button type="submit" class="btn btn-danger btn-sm">
                Delete
              </button>
            </form>
          </div>
          <% } %>

            </div>

        </div>
      <% }) %>

    </div>

  <% } %>

</div>


    
  </div>
</div>

